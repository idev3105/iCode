{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["**/*.ts", "**/*.svelte"],
	"exclude": ["node_modules"]
}
